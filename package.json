{
  "name": "sigmon-tutorial",
  "version": "0.0.1",
  "description": "NestJS observability learning project (Prometheus + Loki + OTel)",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "docker:build": "eval $(minikube docker-env) && docker build -t nestjs-app:latest .",
    "k8s:deploy": "kubectl apply -f k8s/app.yaml",
    "k8s:delete": "kubectl delete -f k8s/app.yaml",
    "k8s:logs": "kubectl logs -l app=nestjs-app -f",
    "k8s:restart": "kubectl rollout restart deployment/nestjs-app",
    "k8s:redeploy": "npm run docker:build && npm run k8s:restart",
    "k8s:grafana:restart":"kubectl rollout restart deployment/prometheus-grafana -n monitoring",
    "k6:1min": "k6 run $(cat k6/config.env | sed 's/^/--env /' | tr '\\n' ' ') ./k6/test-1min.js",
    "k6:3min": "k6 run $(cat k6/config.env | sed 's/^/--env /' | tr '\\n' ' ') ./k6/test-3min.js",
    "k6:5min": "k6 run $(cat k6/config.env | sed 's/^/--env /' | tr '\\n' ' ') ./k6/test-5min.js",
    "pf:app": "kubectl port-forward svc/nestjs-app 8080:8080",
    "pf:grafana": "kubectl port-forward svc/prometheus-grafana 3000:80 -n monitoring",
    "pf:prometheus": "kubectl port-forward svc/prometheus-kube-prometheus-prometheus 9090:9090 -n monitoring",
    "pf:loki": "kubectl port-forward svc/loki 3100:3100 -n monitoring",
    "pf:tempo": "kubectl port-forward svc/tempo 3200:3200 -n monitoring",
    "pf:alloy": "kubectl port-forward svc/alloy 12345:12345 -n monitoring"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@opentelemetry/auto-instrumentations-node": "^0.53.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "nest-winston": "^1.10.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
